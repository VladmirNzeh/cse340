<%- include('../partials/header') -%>

<main>
    <h1>Account Management</h1>

    <% if (messages.notice) { %>
        <div class="notice">
            <%= messages.notice %>
        </div>
    <% } %>
    <!-- Personalized welcome -->
     <h2>Welcome, <%= accountData.account_firstname %>!</h2>
     <p>
        <a href="/account/update/<%= accountData.account_id %>">Update Account Information</a>
     </p>
     <!-- Inventory Management - Only visible to Employee or Admin -->
      <% if (accountData.account_type === 'Employee' || accountData.account_type === 'Admin') { %>
        <h3>Inventory Management</h3>
        <p><a href="/inv/">Manage Inventory</a></p>
        <% } %>
</main>

<%- include('../partials/footer') %>

