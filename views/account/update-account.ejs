<%- include('partials/header') %>

<main>
  <h1>Update Account</h1>

  <!-- Flash messages -->
  <% if (messages.notice) { %>
    <div class="notice">
      <%= messages.notice %>
    </div>
  <% } %>

  <!-- Update account info form -->
  <section>
    <h2>Update Personal Information</h2>
    <form action="/account/update-account" method="POST">
      <input type="hidden" name="account_id" value="<%= account.account_id %>">

      <label for="account_firstname">First Name</label>
      <input type="text" id="account_firstname" name="account_firstname" required value="<%= account.account_firstname %>">

      <label for="account_lastname">Last Name</label>
      <input type="text" id="account_lastname" name="account_lastname" required value="<%= account.account_lastname %>">

      <label for="account_email">Email</label>
      <input type="email" id="account_email" name="account_email" required value="<%= account.account_email %>">

      <button type="submit">Update Info</button>
    </form>
  </section>

  <!-- Change password form -->
  <section>
    <h2>Change Password</h2>
    <form action="/account/update-password" method="POST">
      <input type="hidden" name="account_id" value="<%= account.account_id %>">

      <label for="account_password">New Password</label>
      <input 
        type="password" 
        id="account_password" 
        name="account_password" 
        required
        pattern="(?=.*\d)(?=.*[a-z])(?=.*[A-Z]).{8,}" 
        title="Must be at least 8 characters and include one number, one uppercase and one lowercase letter."
      >

      <p class="password-note">
        Password must be at least 8 characters and contain at least 1 number, 1 uppercase, and 1 lowercase letter.
      </p>

      <button type="submit">Change Password</button>
    </form>
  </section>
</main>

<%- include('../partials/footer') %>
